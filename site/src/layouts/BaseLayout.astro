---
// 页面外壳：<html> + BaseHead + Nav + <slot/> + Footer。
import BaseHead from '../components/BaseHead.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import ConsentBanner from '../components/ConsentBanner.astro';
import { LOCALES, type Lang } from '../lib/i18n';

interface Props {
  lang: Lang;
  title: string;
  description: string;
  path: string;
  ogType?: 'website' | 'article';
  noindex?: boolean;
  /** 隐藏 Nav/Footer（错误页等用）。 */
  bare?: boolean;
}

const { lang, title, description, path, ogType, noindex, bare = false } = Astro.props;
const htmlLang = LOCALES[lang].htmlLang;
---
<!doctype html>
<html lang={htmlLang}>
  <head>
    <BaseHead lang={lang} title={title} description={description} path={path} ogType={ogType} noindex={noindex} />
  </head>
  <body>
    {!bare && <Nav lang={lang} path={path} />}
    <main>
      <slot />
    </main>
    {!bare && <Footer lang={lang} />}
    <ConsentBanner lang={lang} />
  </body>
</html>
