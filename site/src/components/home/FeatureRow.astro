---
import Placeholder from '../Placeholder.astro';
import type { Dict } from '../../lib/i18n';

interface Props {
  feature: Dict['home']['features'][number];
  /** 偶数正常、奇数左右翻转 */
  index: number;
}
const { feature, index } = Astro.props;
const flip = index % 2 === 1;
---
<div class:list={['feature', { flip }]}>
  <div class="feature-text">
    <h2>{feature.title}</h2>
    <p>{feature.body}</p>
    <ul class="feature-points">
      {feature.points.map((pt) => (
        <li>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
          {pt}
        </li>
      ))}
    </ul>
  </div>
  <div class="feature-media">
    <Placeholder dim="1040 × 715" label={feature.shotLabel} ratio="16 / 11" />
  </div>
</div>

<style>
  .feature { display: grid; grid-template-columns: 1fr 1.14fr; gap: clamp(32px, 5vw, 68px); align-items: center; }
  .feature.flip .feature-text { order: 2; }
  .feature.flip .feature-media { order: 1; }
  .feature h2 { font-size: clamp(26px, 3.2vw, 36px); font-weight: 700; letter-spacing: -0.03em; }
  .feature p { margin-top: 16px; max-width: 46ch; color: var(--ink-muted); font-size: 16px; line-height: 1.62; }
  .feature-points { margin-top: 22px; display: flex; flex-direction: column; gap: 13px; list-style: none; }
  .feature-points li { display: flex; gap: 11px; font-size: 15px; color: var(--ink); }
  .feature-points svg { width: 18px; height: 18px; color: var(--accent); flex: none; margin-top: 1px; }

  @media (max-width: 900px) {
    .feature { grid-template-columns: 1fr; gap: 32px; }
    .feature.flip .feature-text, .feature.flip .feature-media { order: initial; }
  }
</style>
