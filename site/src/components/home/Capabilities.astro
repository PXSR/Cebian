---
import { getDict, type Lang } from '../../lib/i18n';
interface Props { lang: Lang; }
const { lang } = Astro.props;
const t = getDict(lang);
const c = t.home.capabilities;
---
<section class="section wrap caps-section">
  <div class="caps-head">
    <h2>{c.heading}</h2>
    <p>{c.lead}</p>
  </div>

  <div class="caps">
    <article class="panel panel-skills">
      <h3>{c.skillsTitle}</h3>
      <p>{c.skillsBody}</p>
      <div class="skill-file">
        <div class="file-bar"><span class="name mono">SKILL.md</span></div>
        <pre class="mono"><span class="dim">---</span>
<span class="k">name</span>: {c.skillExampleName}
<span class="k">description</span>: {c.skillExampleDesc}
<span class="k">metadata</span>:
  <span class="k">author</span>: you
  <span class="k">version</span>: <span class="s">"1.0.0"</span>
  <span class="k">matched-url</span>: <span class="s">"https://*/**"</span>
<span class="dim">---</span></pre>
      </div>
    </article>

    <article class="panel">
      <h3>{c.mcpTitle}</h3>
      <p>{c.mcpBody}</p>
      <div class="mcp-config">
        <div class="cfg-row"><span class="key mono">transport</span><span class="val mono">streamable-http</span></div>
        <div class="cfg-row"><span class="key mono">url</span><span class="val mono">https://example.com/mcp</span></div>
        <div class="cfg-row"><span class="key mono">auth</span><span class="val mono">bearer</span></div>
      </div>
    </article>

    <article class="panel panel-privacy">
      <h3>{c.privacyTitle}</h3>
      <p>{c.privacyBody}</p>
      <div class="privacy-note">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="11" width="18" height="10" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
        {c.privacyNote}
      </div>
    </article>
  </div>
</section>

<style>
  /* h2 lays out full width so it stays one line on desktop; only the lead
     paragraph is width-capped for readability. Both wrap naturally on mobile. */
  .caps-head h2 { font-size: clamp(28px, 3.4vw, 40px); font-weight: 700; letter-spacing: -0.03em; }
  .caps-head p { margin-top: 14px; max-width: 40ch; font-size: 17px; color: var(--ink-muted); }

  .caps { margin-top: clamp(36px, 5vw, 56px); display: grid; grid-template-columns: 1.25fr 1fr; gap: 18px; }
  .panel { border: 1px solid var(--line); border-radius: var(--radius-lg); background: var(--surface); padding: 28px; }
  .panel h3 { font-size: 21px; font-weight: 700; letter-spacing: -0.02em; }
  .panel p { margin-top: 10px; font-size: 15px; color: var(--ink-muted); line-height: 1.6; }
  .panel-skills { grid-row: span 2; display: flex; flex-direction: column; }

  .skill-file { margin-top: 20px; border: 1px solid var(--line); border-radius: var(--radius); background: var(--surface-2); overflow: hidden; }
  .file-bar { padding: 9px 13px; border-bottom: 1px solid var(--line); }
  .file-bar .name { font-size: 12px; color: var(--ink-subtle); }
  .skill-file pre { margin: 0; padding: 14px 16px; overflow-x: auto; font-size: 12.5px; line-height: 1.8; color: var(--ink); white-space: pre-wrap; word-break: break-word; }
  .skill-file .k { color: var(--accent); }
  .skill-file .s { color: var(--ink-muted); }
  .skill-file .dim { color: var(--ink-subtle); }

  .mcp-config { margin-top: 20px; border: 1px solid var(--line); border-radius: var(--radius); background: var(--surface-2); overflow: hidden; }
  .cfg-row { display: flex; align-items: baseline; gap: 14px; padding: 10px 14px; font-size: 12.5px; }
  .cfg-row + .cfg-row { border-top: 1px solid var(--line); }
  .cfg-row .key { color: var(--accent); flex: none; width: 76px; }
  .cfg-row .val { color: var(--ink); min-width: 0; overflow-wrap: anywhere; }

  .panel-privacy { background: var(--accent-wash); border-color: var(--accent-line); }
  .panel-privacy h3 { color: var(--accent-strong); }
  .privacy-note { margin-top: 18px; display: flex; align-items: center; gap: 9px; font-size: 13.5px; color: var(--ink-muted); }
  .privacy-note svg { width: 16px; height: 16px; color: var(--accent); flex: none; }

  @media (max-width: 900px) {
    .caps { grid-template-columns: 1fr; }
    .panel-skills { grid-row: auto; }
  }
</style>
