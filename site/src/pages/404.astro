---
// 404 页。无 locale 前缀，独立外壳。
import BaseHead from '../components/BaseHead.astro';
---
<!doctype html>
<html lang="zh">
  <head>
    <BaseHead lang="zh" title="404 — Cebian" description="Nothing here." path="/404" noindex={true} localized={false} />
  </head>
  <body>
    <main class="wrap" style="min-height: 70dvh; display: grid; place-items: center; text-align: center;">
      <div>
        <p class="mono accent" style="font-size: 48px; font-weight: 800;">404</p>
        <p style="margin-top: 12px; color: var(--ink-muted);">这里什么都没有。</p>
        <a class="btn btn-secondary" href="/zh/" style="margin-top: 24px;">回到首页</a>
      </div>
    </main>
  </body>
</html>
