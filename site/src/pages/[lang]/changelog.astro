---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ReleaseCard from '../../components/changelog/ReleaseCard.astro';
import { getDict, langStaticPaths, type Lang } from '../../lib/i18n';
import { readChangelog, splitReleases } from '../../lib/changelog';

export function getStaticPaths() {
  return langStaticPaths();
}

const lang = Astro.params.lang as Lang;
const t = getDict(lang);
const { shown, folded } = splitReleases(readChangelog(lang));
---
<BaseLayout lang={lang} title={`${t.changelog.title} — ${t.site.name}`} description={t.changelog.lead} path="/changelog">
  <section class="wrap cl">
    <header class="cl-head">
      <h1>{t.changelog.title}</h1>
      <p>{t.changelog.lead}</p>
    </header>

    <div class="cl-list">
      {shown.map((r) => <ReleaseCard release={r} unreleasedLabel={t.changelog.unreleased} />)}

      {folded.length > 0 && (
        <details class="cl-older">
          <summary>
            <span class="cl-older-label">{t.changelog.showOlder.replace('{n}', String(folded.length))}</span>
            <svg class="cl-older-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m6 9 6 6 6-6"/></svg>
          </summary>
          <div class="cl-older-list">
            {folded.map((r) => <ReleaseCard release={r} unreleasedLabel={t.changelog.unreleased} />)}
          </div>
        </details>
      )}
    </div>
  </section>
</BaseLayout>

<style>
  .cl { padding-block: clamp(40px, 6vw, 64px) var(--space-section); max-width: 900px; }
  .cl-head h1 { font-size: clamp(34px, 4.4vw, 52px); font-weight: 800; letter-spacing: -0.035em; }
  .cl-head p { margin-top: 14px; max-width: 60ch; font-size: 17px; color: var(--ink-muted); }

  .cl-list { margin-top: 40px; }
  /* 顶部第一张卡片去掉分隔线 */
  .cl-list > :global(.rel:first-child) { border-top: none; padding-top: 8px; }

  /* 折叠区 */
  .cl-older { border-top: 1px solid var(--line); }
  .cl-older summary {
    display: flex; align-items: center; gap: 8px;
    padding: 20px 0; cursor: pointer; list-style: none;
    font-size: 14px; font-weight: 600; color: var(--ink-muted);
    transition: color .15s;
  }
  .cl-older summary::-webkit-details-marker { display: none; }
  .cl-older summary:hover { color: var(--ink); }
  .cl-older-icon { width: 16px; height: 16px; transition: transform .2s var(--ease); }
  .cl-older[open] > summary .cl-older-icon { transform: rotate(180deg); }
  .cl-older-list > :global(.rel:first-child) { border-top: none; }

  @media (prefers-reduced-motion: reduce) {
    .cl-older-icon { transition: none; }
  }
</style>

<script>
  // ?v=<version> 深链：定位到对应版本卡片，若在折叠区内则先展开，并短暂高亮。
  // ?v=all 直接展开整个折叠区。无 JS 时折叠区仍可手动点开。
  const v = new URLSearchParams(location.search).get('v');
  if (v) {
    const details = document.querySelector<HTMLDetailsElement>('details.cl-older');
    if (v === 'all') {
      if (details) details.open = true;
    } else {
      const el = document.querySelector<HTMLElement>(`[data-version="${CSS.escape(v)}"]`);
      if (el) {
        if (details && details.contains(el)) details.open = true;
        const reduce = matchMedia('(prefers-reduced-motion: reduce)').matches;
        el.scrollIntoView({ behavior: reduce ? 'auto' : 'smooth', block: 'start' });
        el.classList.add('is-target');
        setTimeout(() => el.classList.remove('is-target'), 2100);
      }
    }
  }
</script>
