---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getDict, localePath, langStaticPaths, type Lang } from '../../../lib/i18n';
import { getDocsFor, groupDocs } from '../../../lib/docs';

export function getStaticPaths() {
  return langStaticPaths();
}

const lang = Astro.params.lang as Lang;
const t = getDict(lang);
const docs = await getDocsFor(lang);
const groups = groupDocs(docs, t.docs.groups);
---
<BaseLayout lang={lang} title={`${t.docs.title} — ${t.site.name}`} description={t.docs.lead} path="/docs">
  <section class="wrap docs-index">
    <header class="docs-index-head">
      <h1>{t.docs.title}</h1>
      <p>{t.docs.lead}</p>
    </header>

    {groups.map((g) => (
      <section class="docs-index-group">
        <h2>{g.label}</h2>
        <ul>
          {g.items.map((m) => (
            <li>
              <a href={localePath(lang, m.path)}>
                <span class="t">{m.title}</span>
                <span class="d">{m.description}</span>
              </a>
            </li>
          ))}
        </ul>
      </section>
    ))}
  </section>
</BaseLayout>

<style>
  .docs-index { padding-block: clamp(40px, 6vw, 64px) var(--space-section); }
  .docs-index-head h1 { font-size: clamp(34px, 4.4vw, 52px); font-weight: 800; letter-spacing: -0.035em; }
  .docs-index-head p { margin-top: 14px; max-width: 56ch; font-size: 17px; color: var(--ink-muted); }

  .docs-index-group { margin-top: 44px; }
  .docs-index-group > h2 { font-size: 14px; font-weight: 700; color: var(--ink-subtle); letter-spacing: 0.02em; }
  .docs-index-group ul { list-style: none; margin-top: 16px; display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 12px; }
  .docs-index-group a {
    display: flex; flex-direction: column; height: 100%; padding: 18px 20px;
    border: 1px solid var(--line); border-radius: var(--radius);
    background: var(--surface); transition: border-color .15s, transform .15s var(--ease);
  }
  .docs-index-group a:hover { border-color: var(--ink-subtle); transform: translateY(-2px); }
  .docs-index-group .t { display: block; font-size: 16px; font-weight: 700; color: var(--ink); }
  .docs-index-group .d { display: block; margin-top: 6px; font-size: 13.5px; color: var(--ink-muted); line-height: 1.5; }
</style>
