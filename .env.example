# Cebian local dev environment template.
#
# Copy this file to `.env.local` (gitignored) and fill in the values to
# auto-seed a custom AI provider on first dev launch. All `WXT_DEV_*`
# variables are ONLY read when the extension is built in dev mode
# (`pnpm dev`); production builds completely skip this logic.
#
# Seed behavior:
#   - On background startup, if `WXT_DEV_API_KEY` is set AND no provider
#     with id `dev` already exists in storage, a provider named after
#     `WXT_DEV_PROVIDER_NAME` is created and its credentials saved.
#   - If `activeModel` is currently unset, the seeded model is selected as
#     active. An already-chosen model is never overwritten.
#   - If a provider with id `dev` already exists (you ran dev before, or
#     manually created one), the entire seed is skipped — your edits win.

# Required: gates the entire seed. Leave empty to disable.
WXT_DEV_API_KEY=

# Required when API key is set: OpenAI-compatible base URL.
WXT_DEV_BASE_URL=https://api.openai.com/v1

# Required when API key is set: the model id sent to the provider.
WXT_DEV_MODEL_ID=gpt-4o-mini

# Optional: display name shown in the UI. Defaults to "Dev Provider".
WXT_DEV_PROVIDER_NAME=Dev Provider

# Optional: display name for the model. Defaults to WXT_DEV_MODEL_ID.
WXT_DEV_MODEL_NAME=

# Optional: whether the model supports reasoning. "true" enables it.
WXT_DEV_MODEL_REASONING=false
